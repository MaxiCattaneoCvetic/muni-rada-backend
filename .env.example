# ================================================
# SUMINISTROS MUNICIPALIDAD - Backend Config
# ================================================

# Server
PORT=3000
NODE_ENV=development

# Database: preferí DATABASE_URL (Railway, Supabase, etc.). Si no está definida, se usan DATABASE_*.
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
# En hosts gestionados suele hacer falta DATABASE_SSL=true (o ?sslmode=require en la URL).

# Opción A — URL única (recomendado en producción)
# DATABASE_URL=postgresql://postgres:PASSWORD@db.xxxxxxxxxxxx.supabase.co:5432/postgres
# DATABASE_SSL=true

# Opción B — variables separadas (ej. Docker local con npm run db:up)
DATABASE_HOST=localhost
DATABASE_PORT=15432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres123
DATABASE_NAME=suministros
DATABASE_SSL=false

# Opción C — Supabase sin URL (legado)
# DATABASE_HOST=db.xxxxxxxxxxxx.supabase.co
# DATABASE_PORT=5432
# DATABASE_USER=postgres
# DATABASE_PASSWORD=your_supabase_db_password
# DATABASE_NAME=postgres
# DATABASE_SSL=true

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=8h

# Supabase (para storage de archivos)
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key
SUPABASE_STORAGE_BUCKET=suministros

# CORS — uno o varios orígenes separados por coma (producción: URL pública del front)
# Ej. Railway: FRONTEND_URL=https://tu-front.up.railway.app,http://localhost:5173
FRONTEND_URL=http://localhost:5173
# Alternativa al mismo efecto:
# CORS_ORIGINS=https://tu-front.up.railway.app

# Demo: POST /api/auth/demo { "rol": "secretaria"|"compras"|"tesoreria"|"admin" } sin contraseña
# DEMO_MODE=true

# Config del sistema (puede sobreescribirse desde la DB)
SELLADO_UMBRAL=350000
MIN_PRESUPUESTOS=3
