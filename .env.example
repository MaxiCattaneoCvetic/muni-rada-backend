# ================================================
# SUMINISTROS MUNICIPALIDAD - Backend Config
# ================================================

# Server
PORT=3000
NODE_ENV=development

# Database (Supabase PostgreSQL)
DATABASE_HOST=db.xxxxxxxxxxxx.supabase.co
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=your_supabase_db_password
DATABASE_NAME=postgres
DATABASE_SSL=true

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=8h

# Supabase (para storage de archivos)
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key
SUPABASE_STORAGE_BUCKET=suministros

# CORS - Frontend URL
FRONTEND_URL=http://localhost:5173

# Config del sistema (puede sobreescribirse desde la DB)
SELLADO_UMBRAL=350000
MIN_PRESUPUESTOS=3
